# URL de base de l'API IPCK.
# DEV local : 3333 (3000 occupé par Supabase)
VITE_API_URL=http://localhost:3333/api/v1
#
# PROD (Vercel) : définie dans .env.production OU dans
# Vercel → Settings → Environment Variables, p.ex. :
#   VITE_API_URL=https://VOTRE-BACKEND.up.railway.app/api/v1
#
# ⚠️ Le backend doit autoriser le domaine Vercel dans CORS_ORIGINS, p.ex. :
#   CORS_ORIGINS=https://ipck-admin.vercel.app
