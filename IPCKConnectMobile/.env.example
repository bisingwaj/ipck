# Modèle de configuration mobile. Copiez en `.env` (gitignoré) pour le dev local.
# Toutes les variables exposées au bundle DOIVENT être préfixées EXPO_PUBLIC_.

# URL de base de l'API IPCK (avec le suffixe de version /api/v1).
#  - Prod (par défaut si non défini, voir src/api/config.ts) : Railway.
#  - Dev sur appareil physique : l'IP LAN de votre machine, ex. http://192.168.1.20:3333/api/v1
#  - Dev sur émulateur Android : http://10.0.2.2:3333/api/v1
#  - Dev web / iOS simulateur : http://localhost:3333/api/v1
EXPO_PUBLIC_API_URL=https://ipck-production.up.railway.app/api/v1

# true = fixtures locales (src/data/mock.ts), aucun appel réseau. false = API réelle.
EXPO_PUBLIC_USE_MOCKS=false
