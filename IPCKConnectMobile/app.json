{
  "expo": {
    "name": "IPCK Connect",
    "slug": "ipck-connect",
    "scheme": "ipckconnect",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#F7F5F0",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "cd.ipck.connect"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1F6FEB"
      },
      "package": "cd.ipck.connect"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-asset",
      "expo-secure-store",
      "expo-video"
    ],
    "extra": {
      "eas": {
        "projectId": "ec98537f-836b-4bcd-ad13-7e885ddf8989"
      }
    },
    "owner": "david24300",
    "newArchEnabled": false
  }
}
