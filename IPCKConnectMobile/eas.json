{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "demo": {
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "env": {
        "EXPO_PUBLIC_USE_MOCKS": "true"
      }
    },
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "http://localhost:3333/api/v1",
        "EXPO_PUBLIC_USE_MOCKS": "false"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "ios": { "simulator": false },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://staging-api.ipck.example/api/v1",
        "EXPO_PUBLIC_USE_MOCKS": "false"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": { "buildType": "app-bundle" },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.ipck.example/api/v1",
        "EXPO_PUBLIC_USE_MOCKS": "false"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
