# ──────────────────────────────────────────────────────────────
# IPCK Backend — variables d'environnement (copier vers backend/.env)
# Les SECRETS ne doivent jamais être committés ni exposés au mobile.
# ──────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
PORT=3000
# Origines CORS autorisées (séparées par des virgules). * en dev uniquement.
CORS_ORIGINS=http://localhost:5173,http://localhost:19006

# Base de données (PostgreSQL 16) — correspond à docker-compose.yml
DATABASE_URL=postgresql://ipck:ipck@localhost:5432/ipck?schema=public

# Cache / files (Redis 7)
REDIS_URL=redis://localhost:6379

# JWT — générer des secrets forts en prod (openssl rand -base64 48)
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_ACCESS_TTL=900            # secondes (15 min)
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_REFRESH_TTL=2592000       # secondes (30 jours)

# OTP
OTP_TTL=300                   # secondes (5 min)
OTP_LENGTH=6
# OTP passe-partout (tests uniquement) : ce code marche pour tout numéro, en login comme en
# inscription. Laisser vide pour désactiver. Ignoré en production (NODE_ENV=production).
DEV_MASTER_OTP=
# console = log l'OTP en dev ; twilio = provider réel (Phase 8)
SMS_PROVIDER=console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# Paiement mobile money / carte — fournisseur abstrait
# mock = simulateur local (dev/test) ; flexpay / stripe = réels (Phase 8)
PAYMENT_PROVIDER=mock
PAYMENT_WEBHOOK_SECRET=dev_webhook_secret_change_me
FLEXPAY_API_KEY=
FLEXPAY_MERCHANT=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Push (Expo)
EXPO_ACCESS_TOKEN=

# Stockage fichiers (S3-compatible : Cloudflare R2 / Supabase)
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto

# Observabilité
LOG_LEVEL=debug
SENTRY_DSN=
